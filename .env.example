# ============================================================================
# City Agent Aria (DocSensei) — environment template
# Copy to .env and fill in. .env is gitignored — NEVER commit real secrets.
#   cp .env.example .env
# Only the keys under REQUIRED must be set; everything else has safe defaults.
# ============================================================================

# ---- REQUIRED ----------------------------------------------------------------
# OpenRouter API key (LLM). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT signing secret — MUST be >=32 chars, random, unique per deploy.
# Generate: openssl rand -hex 32     (rotating this logs everyone out)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Super-admin bootstrap. With signup disabled this is the ONLY way to get an
# admin. Set both; on every boot the user is (re)created as admin with this
# password — env is the source of truth (change password = change env + restart).
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me-strong-password

# ---- Database ----------------------------------------------------------------
# In Docker the compose file already wires this to the bundled postgres.
DATABASE_URL=postgresql://docsensei:docsensei@db:5432/docsensei
PG_MAX_CONNECTIONS=200
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30

# ---- Server / scaling --------------------------------------------------------
APP_ENV=production
WEB_CONCURRENCY=2            # uvicorn workers (daemons run in leader worker only)
LLM_MAX_CONCURRENCY=6        # cap concurrent LLM calls (0 = unlimited)
CORS_ALLOW_ORIGINS=*         # tighten to your domain(s) in production
# Optional legacy API key for /api access (separate from JWT)
API_KEY=

# ---- Models (OpenRouter slugs) ----------------------------------------------
INGEST_MODEL=google/gemini-2.5-flash-lite
CHAT_MODEL=google/gemini-2.5-flash-lite
COMPILE_MODEL=google/gemini-2.5-flash-lite

# ---- Retrieval / answering ---------------------------------------------------
RETRIEVE_K=8
RETRIEVE_DEPTH=40
RETRIEVE_EXPAND=1
RETRIEVE_RERANK=1
RERANK_POOL=24
CHAT_USE_WIKI=1
COMPILE_ON_INGEST=1
AUTO_ROUTE_ENABLED=1
AUTO_ROUTE_LLM=0            # 1 = LLM tie-break on quick/deep routing (extra hop)
AGENTIC_RETRIEVE_ENABLED=1
AGENTIC_MAX_SUBS=1

# ---- Ingest / vision ---------------------------------------------------------
VISION_PREREAD=1
VISION_WORKERS=3
AUTO_CATEGORIZE=1
IMPORT_DIR=/app/documents   # server-folder bulk import source

# ---- Storage backend ---------------------------------------------------------
STORAGE=local               # local | s3
DATA_DIR=/app/data
PAGES_DIR=/app/data/pages
UPLOADS_DIR=/app/data/uploads
# S3 / MinIO (only when STORAGE=s3)
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=aria
S3_IMPORT_PREFIX=
S3_FORCE_PATH_STYLE=1

# ---- Self-learning (facts + Q&A bank) ---------------------------------------
AUTO_LEARN_ENABLED=1
AUTO_LEARN_MODE=per_answer   # per_answer | nightly
AUTO_LEARN_MIN_CONF=0.7
AUTO_APPROVE_MIN_CONF=0.95
AUTO_LEARN_MAX_PER_CONV=5
AUTO_FACTS_ENABLED=1
AUTO_FACTS_MAX=8
AUTO_QA_ENABLED=1
AUTO_QA_MAX=12
AUTO_QA_HARVEST=1
AUTO_QA_SERVE_ENABLED=1
AUTO_QA_SERVE_MIN_SIM=0.72
AUTO_QA_GAP_ENABLED=0
AUTO_QA_GAP_INTERVAL_H=24
AUTO_QA_GAP_PER_DAY=20

# ---- Background daemons / ops ------------------------------------------------
OPS_AGENT_ENABLED=1
VERIFY_ENABLED=0             # answer self-grading (LLM cost) — off by default
VERIFY_FLAG_THRESHOLD=70
USAGE_ROLLUP_ENABLED=1
DB_MAINTENANCE_ENABLED=1
DB_MAINTENANCE_INTERVAL_H=24
DB_SESSION_TTL_DAYS=2
EMBED_PRUNE_ENABLED=1
EMBED_PRUNE_INTERVAL_H=24
EMBED_EVENT_TTL_DAYS=30
EMBED_VISITOR_TTL_DAYS=90
EMBED_TOKEN_TTL_MIN=60

# ---- Auth hardening ----------------------------------------------------------
LOGIN_MAX_FAIL=5
LOGIN_LOCK_MIN=15

# ---- Sharing -----------------------------------------------------------------
SHARE_ENABLED=1
SHARE_PUBLIC_ENABLED=0

# ---- Alerting (optional) -----------------------------------------------------
ALERT_WEBHOOK_URL=          # Slack-style {text} webhook; empty = disabled
ALERT_COOLDOWN_SEC=300
