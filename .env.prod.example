# ---- production env (copy to .env.prod, fill in, never commit secrets) ----
# Used by docker-compose.prod.yml (app + worker via env_file).

# REQUIRED
OPENROUTER_API_KEY=sk-or-...
JWT_SECRET=change-me-to-a-64-char-random-string-................................
APP_ENV=production
PUBLIC_URL=https://aria.yourco.com
CORS_ALLOW_ORIGINS=https://aria.yourco.com

# first admin (bootstrapped once on empty DB) — use a strong password
SUPERADMIN_EMAIL=admin@yourco.com
SUPERADMIN_PASSWORD=change-me-strong

# ---- database ----
# Self-hosted: leave as-is (uses the compose `db` service).
# Managed PG (recommended): point at RDS / Cloud SQL and delete the db service.
DATABASE_URL=postgresql://docsensei:docsensei@db:5432/docsensei
POSTGRES_USER=docsensei
POSTGRES_PASSWORD=change-me
POSTGRES_DB=docsensei
PG_MAX_CONNECTIONS=200

# ---- concurrency (tune to your box + OpenRouter rate tier) ----
# Pool math MUST hold: replicas × WEB_CONCURRENCY × DB_POOL_MAX + ~15 < PG_MAX_CONNECTIONS
WEB_CONCURRENCY=4
DB_POOL_MIN=2
DB_POOL_MAX=10
LLM_MAX_CONCURRENCY=30

# ingest off the API → handled by the worker service
INGEST_IN_API=0
WORKER_VISION_WORKERS=12

# ---- object storage (REQUIRED for multi-host / multi-node scale) ----
# Single host with `--scale app=N` can skip S3 (replicas share ./data). For
# Swarm/k8s/multi-host, set STORAGE=s3 so every replica reads images from S3.
STORAGE=local
# STORAGE=s3
# S3_BUCKET=aria-prod
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# ---- cost lever: keep the zero-LLM Q&A cache ON ----
AUTO_QA_SERVE_ENABLED=1

# models
CHAT_MODEL=google/gemini-3.1-flash-lite
INGEST_MODEL=openrouter/google/gemini-3.1-flash-lite

# optional: alert webhook for warn/error events
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...
