{
  "realm": "docsensei",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "docsensei",
      "name": "City Agent Aria",
      "enabled": true,
